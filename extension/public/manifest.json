{
  "manifest_version": 3,
  "name": "ShadowSense Aurora",
  "version": "1.0.0",
  "description": "AI-powered scam detection for Fiverr and Upwork — chat protection + pre-engagement trust scoring",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://www.fiverr.com/*",
    "https://www.upwork.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShadowSense Aurora"
  },
  "content_scripts": [
    {
      "matches": ["https://www.fiverr.com/inbox*", "https://www.fiverr.com/inbox/*"],
      "js": ["content/fiverr.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.fiverr.com/*"],
      "js": ["content/fiverr_gig.js"],
      "run_at": "document_idle",
      "exclude_matches": ["https://www.fiverr.com/inbox*"]
    },
    {
      "matches": [
        "https://www.upwork.com/jobs/*",
        "https://www.upwork.com/nx/search/jobs/*",
        "https://www.upwork.com/ab/jobs/search/*",
        "https://www.upwork.com/freelance-jobs/*"
      ],
      "js": ["content/upwork_gig.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
