# =============================================================================
# ShadowSense Aurora — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values before starting the server.
# NEVER commit .env to git (it is already in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0          # Host to bind (use 127.0.0.1 to disable external access)
API_PORT=8000             # Port the FastAPI server listens on
DEBUG=False               # Set True for hot-reload during development

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console        # console (human-readable) | json (structured, for log aggregators)

# -----------------------------------------------------------------------------
# Groq API — LinguisticAgent (primary LLM)
# Get your key at: https://console.groq.com
# REQUIRED — server will refuse to start without at least one valid key.
# -----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here

# Optional: comma-separated list for key rotation (round-robin, avoids rate limits)
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Model to use (llama-4-scout is resolved to the full model name automatically)
GROQ_MODEL=llama-4-scout

# -----------------------------------------------------------------------------
# Google Gemini API — IdentityAgent + LinguisticAgent fallback
# Get your key at: https://aistudio.google.com/app/apikey  (free tier available)
# REQUIRED — server will refuse to start without at least one valid key.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: comma-separated list for key rotation
# GEMINI_API_KEYS=AIzaSy_key1,AIzaSy_key2

# -----------------------------------------------------------------------------
# Ollama — PayloadAgent (local DeepSeek-R1 inference, privacy-first)
# Install Ollama: https://ollama.com  |  then: ollama pull deepseek-r1:8b
# OPTIONAL — if Ollama is unavailable, payload analysis is gracefully skipped.
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
DEEPSEEK_MODEL=deepseek-r1   # Use deepseek-r1:8b or deepseek-r1:14b if you have VRAM

# -----------------------------------------------------------------------------
# ChromaDB — Vector memory for scam pattern similarity
# OPTIONAL — if ChromaDB is unavailable, similarity-based scoring is skipped.
# -----------------------------------------------------------------------------
CHROMADB_PATH=./data/chromadb

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///shadowsense.db

# -----------------------------------------------------------------------------
# CrewAI
# -----------------------------------------------------------------------------
CREWAI_VERBOSE=True       # Set False to suppress agent step-by-step logs

# -----------------------------------------------------------------------------
# Chrome Extension
# -----------------------------------------------------------------------------
EXTENSION_ID=shadowsense-aurora
BACKEND_URL=http://localhost:8000
